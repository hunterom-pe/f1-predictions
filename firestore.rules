rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserOwned(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if a user is not anonymous
    function isFullyAuthenticated() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Strict validation to prevent rich media (base64 image strings, HTML, etc.)
    function isStrictTextOnly(text) {
      return text is string 
             && text.size() <= 2000
             && !text.matches('.*data:image/.*') 
             && !text.matches('.*<img.*')
             && !text.matches('.*\\[img\\].*');
    }

    // Users Collection — PRIVATE. Holds sensitive fields (email, device uuid,
    // flag_count, reporterIds, ban state). Only the owner may read their own doc.
    // Other users see public fields via the /profiles mirror below.
    match /users/{userId} {
      allow read: if isUserOwned(userId);
      // Allow users to initialize/update their own document
      allow create: if isUserOwned(userId);
      // Clients may only update their own doc, homeCity is immutable once set,
      // and server-managed fields (flag_count, banned, reporterIds, isAdmin, isBanned)
      // can only be written by Cloud Functions via the Admin SDK.
      allow update: if (isUserOwned(userId)
                    && (
                      !("homeCity" in resource.data)
                      || request.resource.data.homeCity == resource.data.homeCity
                    )
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['isAdmin', 'banned', 'flag_count', 'reporterIds', 'isBanned']
                       )) || request.auth.token.admin == true;
    }

    // Public Profiles Collection — read-only mirror of non-sensitive user fields,
    // maintained exclusively by the syncProfile Cloud Function (Admin SDK).
    // Any authenticated user may read; no client may write.
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Blacklisted Devices Collection
    match /blacklisted_devices/{deviceUuid} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions / Admin can write here
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      // Posts are created exclusively via the createPostSecure Cloud Function (via Admin SDK).
      allow create: if false;
      allow update: if isAuthenticated() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['thumbsUpCount']) ||
        (request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'connectedWithId', 'connectedWithUsername', 'connectedProofText'])) ||
        request.auth.token.admin == true
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Connections Collection (Blind Proofs)
    match /connections/{connectionId} {
      // Single-document reads: only sender or receiver
      allow get: if isAuthenticated() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId
      );
      // Collection queries: allow authenticated users (app queries by senderId or receiverId)
      allow list: if isAuthenticated();
      
      // Connections are created exclusively by the createConnectionSecure Cloud
      // Function (via the Admin SDK, which bypasses these rules). Direct client
      // creation is forbidden so that proof-text moderation and the per-day claim
      // throttle cannot be skipped by a scripted client.
      allow create: if false;

      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.receiverId &&
        request.resource.data.status in ['accepted', 'rejected'] &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['senderId', 'receiverId', 'postId', 'proofText', 'venueName', 'postText', 'timestamp']
        )
      );
      
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId
      );
    }

    // Chats Collection
    match /chats/{chatId} {
      // Single-document reads: user must be a participant
      allow get: if isAuthenticated() && request.auth.uid in resource.data.participants;
      // Collection queries: allow when filtering by participants (array-contains)
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() 
                    && request.auth.uid in request.resource.data.participants
                    && get(/databases/$(database)/documents/connections/$(request.resource.data.connectionId)).data.status == 'accepted'
                    && request.resource.data.participants.hasAll([
                      get(/databases/$(database)/documents/connections/$(request.resource.data.connectionId)).data.senderId,
                      get(/databases/$(database)/documents/connections/$(request.resource.data.connectionId)).data.receiverId
                    ]);
      allow update: if isAuthenticated() 
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.participants == resource.data.participants
                    && request.resource.data.connectionId == resource.data.connectionId;
      allow delete: if false;

      // Messages Subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.senderId == request.auth.uid
                      && isStrictTextOnly(request.resource.data.text);
        allow update, delete: if false; // Messages are immutable once sent
      }
    }

    // Appeals Collection
    match /appeals/{appealId} {
      allow read: if isAuthenticated() && (request.auth.token.admin == true || request.auth.uid == "sysop_admin");
      allow create: if isFullyAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Appeals are immutable once submitted
    }

    // SysOp Audit Log — write-once, no reads from client
    // Authenticated clients can append records; only Cloud Functions / Admin SDK can read them
    match /admin_audit_log/{logId} {
      allow create: if false; // Only Cloud Functions can append admin audit logs
      allow read, update, delete: if false; // Tamper-proof from client side
    }
  }
}
