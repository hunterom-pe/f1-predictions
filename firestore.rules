rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserOwned(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if a user is not anonymous
    function isFullyAuthenticated() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Strict validation to prevent rich media (base64 image strings, HTML, etc.)
    function isStrictTextOnly(text) {
      return text is string 
             && text.size() <= 2000
             && !text.matches('.*data:image/.*') 
             && !text.matches('.*<img.*')
             && !text.matches('.*\\[img\\].*');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to initialize/update their own document
      allow create: if isUserOwned(userId);
      allow update: if (isUserOwned(userId) 
                    && (
                      // Either homeCity is not changing, or it is being set for the first time
                      !("homeCity" in resource.data) 
                      || request.resource.data.homeCity == resource.data.homeCity
                    ))
                    || (isAuthenticated() && request.resource.data.flag_count == resource.data.flag_count + 1); // Anyone logged in can increment flags
    }

    // Blacklisted Devices Collection
    match /blacklisted_devices/{deviceUuid} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions / Admin can write here
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      // Must be a fully registered (non-anonymous) user to create posts
      allow create: if isFullyAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && isStrictTextOnly(request.resource.data.text)
                    && request.resource.data.venueId is string
                    && request.resource.data.venueName is string
                    && request.resource.data.venueAddress is string
                    && request.resource.data.venueCity is string
                    && request.resource.data.venueZone is string
                    && request.resource.data.date is string
                    && request.resource.data.timeRange is string
                    // Enforce that post venueCity matches the user's permanent homeCity in Firestore
                    && request.resource.data.venueCity == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.homeCity;
      allow update, delete: if false; // Missed connection posts are immutable
    }

    // Connections Collection (Blind Proofs)
    match /connections/{connectionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId
      );
      
      // Must be a fully registered user to create a connection request
      allow create: if isFullyAuthenticated()
                    && request.resource.data.senderId == request.auth.uid
                    && isStrictTextOnly(request.resource.data.proofText)
                    && request.resource.data.receiverId is string
                    && request.resource.data.postId is string
                    && request.resource.data.venueName is string
                    && request.resource.data.postText is string
                    && request.resource.data.status == 'pending';
                    
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.receiverId &&
        request.resource.data.status in ['accepted', 'rejected'] &&
        request.resource.data.proofText == resource.data.proofText // Cannot edit the proof itself
      );
      
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId
      );
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

      // Messages Subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.senderId == request.auth.uid
                      && isStrictTextOnly(request.resource.data.text);
        allow update, delete: if false; // Messages are immutable once sent
      }
    }
  }
}
